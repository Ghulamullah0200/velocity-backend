# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection (replace with your actual MongoDB URI)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/velocity-cash?retryWrites=true&w=majority

# JWT Secret (replace with a strong random secret)
JWT_SECRET=your-super-secure-jwt-secret-key-here-change-this-in-production

# API Base URL (for serving files correctly)
API_URL=http://localhost:5000

# Optional: Email service configuration
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
